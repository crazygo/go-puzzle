build/ai_arena/*.jsonl
build/ai_arena/logs/**

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
/android/local.properties

# iOS CocoaPods (generated at build time)
ios/Pods/
ios/Podfile.lock
ios/.symlinks/

# iOS Xcode derived data
ios/DerivedData/
ios/*.xcarchive
ios/*.ipa

# Flutter generated iOS files (regenerated by `flutter pub get`)
ios/Flutter/flutter_export_environment.sh
ios/Flutter/Generated.xcconfig
ios/Flutter/Local.xcconfig
ios/Flutter/Flutter.podspec
ios/Flutter/ephemeral/

# Vercel
.vercel/

# Node.js dependencies
node_modules/

# Web Worker compiled output (built from web/ai_search_worker.dart at build time)
web/ai_search_worker.dart.js

# Runtime recognition models are downloaded from GitHub Releases during dev
# bootstrap and must not be committed to git.
assets/models/recognition/*.onnx
web/recognition_models/*.onnx

# Git worktrees
.worktree/
